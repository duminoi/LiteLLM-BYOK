# =============================================================
# LiteLLM BYOK proxy - environment variables template
# Copy file nay thanh .env va dien API key cua ban.
# File .env KHONG duoc commit vao git (da co trong .gitignore).
# =============================================================

# OpenCode Go API key (BYOK = bring your own key)
# Lay tu https://opencode.ai dashboard cua ban
OPENCODE_GO_API_KEY=sk-your-opencode-go-api-key-here

# Master key cho LiteLLM proxy (tu dat, phuc vu auth khi goi /v1/*)
# Phai khop voi gia tri trong config.yaml (general_settings.master_key)
LITELLM_MASTER_KEY=sk-litellm-master-key-1234
